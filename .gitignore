# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# rust / soroban contract build artifacts
/contracts/**/target/
# Cargo.lock IS committed: these contracts are binaries that get deployed on
# chain, not libraries. Without it CI re-resolves every dependency to latest and
# builds something that is not what was tested — which is how a 1.81 build broke
# on a transitive dep needing edition2024.

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code local settings (shared: settings.json, launch.json)
.claude/settings.local.json
.claude/*.local.json

.vercel


# Graphify code-graph output (local, regenerated)
graphify-out/
**/graphify-out/
